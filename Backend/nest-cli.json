{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true
  },
  "projects": {
    "wasel-platform": {
      "type": "application",
      "root": "src",
      "entryFile": "main",
      "sourceRoot": "src",
      "compilerOptions": {
        "deleteOutDir": true
      }
    }
  },
  "schematics": {
    "@nestjs/schematics:controller": {
      "spec": true,
      "flat": false,
      "pascalCaseFiles": false
    },
    "@nestjs/schematics:service": {
      "spec": true
    },
    "@nestjs/schematics:module": {
      "spec": true
    }
  }
}
